{
  "manifest_version": 3,
  "name": "PR Buddy",
  "version": "1.1.0",
  "description": "AI-powered PR review assistant - Author training and reviewer Q&A",

  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting",
    "sidePanel"
  ],

  "host_permissions": [
    "https://github.com/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["src/content/content-script.js"],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_title": "PR Buddy"
  },

  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "src/sidepanel/audio-processor.js",
        "src/sidepanel/request-mic.html"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
